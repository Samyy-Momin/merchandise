{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "onefooddialer/merchandise-service-v12",
    "type": "project",
    "description": "OneFoodDialer 2025 Merchandise Service \u2014 Bulk Procurement Microservice",
    "license": "MIT",
    "require": {
        "cubeonebiz/chassis": "@dev",
        "cubeonebiz/resilience": "@dev",
        "cubeonebiz/tenant": "@dev",
        "laravel/boost": "^2.3",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.1",
        "laravel/tinker": "^2.10.1",
        "php": "^8.3"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.8",
        "phpstan/phpstan": "*",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php artisan migrate --graceful --ansi"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "test:unit": [
            "vendor/bin/pest --testsuite=Unit --colors=always"
        ],
        "test:feature": [
            "vendor/bin/pest --testsuite=Feature --colors=always"
        ],
        "test:coverage": [
            "vendor/bin/pest --coverage --min=80 --colors=always"
        ],
        "format": [
            "vendor/bin/pint"
        ],
        "format:test": [
            "vendor/bin/pint --test"
        ],
        "analyse": [
            "vendor/bin/phpstan analyse --configuration=phpstan.neon --memory-limit=512M"
        ],
        "quality": [
            "@format:test",
            "@analyse",
            "@test:coverage"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "repositories": [
        {
            "name": "tenant",
            "type": "path",
            "url": "../../packages/tenant"
        },
        {
            "type": "path",
            "url": "../../packages/resilience"
        },
        {
            "name": "chassis",
            "type": "path",
            "url": "../../packages/chassis"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true
}
