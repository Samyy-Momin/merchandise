APP_NAME="Merchandise Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=json
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=merchandise_service
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Keycloak / JWT Authentication
KEYCLOAK_BASE_URL=http://keycloak:8080
KEYCLOAK_REALM=onefooddialer
KEYCLOAK_CLIENT_ID=merchandise-service
KEYCLOAK_CLIENT_SECRET=

# Inter-service URLs
AUTH_SERVICE_URL=http://auth-service-v12:8101
CUSTOMER_SERVICE_URL=http://customer-service-v12:8102

CHASSIS_AUTO_REGISTER_ROUTES=false
CHASSIS_ROUTE_PREFIX=api/v2/chassis
CHASSIS_HEALTH_PATH=health
CHASSIS_READINESS_PATH=ready
CHASSIS_METRICS_PATH=metrics
CHASSIS_READINESS_CHECK_DATABASE=true
CHASSIS_READINESS_CHECK_CACHE=false
CHASSIS_READINESS_CHECK_QUEUE=false
